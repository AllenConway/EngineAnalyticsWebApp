<div class="row mt-4">
    <div class="col-xl-8 col-lg-10">
        <div class="card">
            <div class="card-body">
                <EditForm Model="@automobile" OnValidSubmit="@HandleValidSubmit" OnInvalidSubmit="@HandleInValidSubmit">
                    <DataAnnotationsValidator />
                    @*Using a fully qualified namespace as 'ValidationSummary' also exists in Blazorise*@
                    <Microsoft.AspNetCore.Components.Forms.ValidationSummary />

                    <CascadingValue Value="automobile">
                        <AutoGroup></AutoGroup>
                    </CascadingValue>

                    <div class="form-group row mt-3">
                        @if (automobile.Horsepower != null)
                        {
                            <div class="col-sm-6">
                                <label for="vehicleWeight">Weight</label>
                                @*<input class="form-control" id="vehicleWeight" placeholder="Enter Vehicle Weight" @bind-value=automobile.Calculations.Weight @onclick="ClearForm" />*@
                                <InputNumber class="form-control" id="vehicleWeight" placeholder="Enter Vehicle Weight" @bind-Value=automobile.Horsepower.Weight @onclick="ClearForm"></InputNumber>
                            </div>
                            <div class="col-sm-6">
                                <label for="estimatedTime">1/4 Mile ET</label>
                                @*<input class="form-control" id="estimatedTime" placeholder="Enter 1/4 Time in Seconds" @bind-value=automobile.Calculations.EstimatedTime @onclick="ClearForm" />*@
                                <InputNumber class="form-control" id="estimatedTime" placeholder="Enter 1/4 Time in Seconds" @bind-Value=automobile.Horsepower.EstimatedTime @onclick="ClearForm"></InputNumber>
                            </div>
                        }
                    </div>
                    <button type="submit" class="btn btn-primary mt-3">Submit</button>
                    <div class="form-group row mt-3">
                        @if (automobile.EngineAnalytics != null)
                        {
                            <div class="col-sm-6">
                                <label for="estimatedFlywheelHorsePower">Estimated Flywheel Engine Horsepower</label>
                                <input type="text" class="form-control" id="estimatedFlywheelHorsePower" @bind-value=automobile.EngineAnalytics.FlywheelHorsepower>
                            </div>
                            <div class="col-sm-6">
                                <label for="estimatedRearWheelHorsePower">Estimated Rear Wheel Engine Horsepower (15% drivetrain loss)</label>
                                <input type="text" class="form-control" id="estimatedRearWheelHorsePower" @bind-value=automobile.EngineAnalytics.RearWheelHorsepower>
                            </div>
                        }
                    </div>
                    <div class="alert @alertClass mt-3" role="alert">@statusMessage</div>
                </EditForm>
            </div>
        </div>
    </div>
</div>